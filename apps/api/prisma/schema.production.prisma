generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  SUSPENDED
}

enum LinkStatus {
  PROPOSED
  CONFIRMED
  DISPUTED
  REJECTED
}

enum SuggestionType {
  THERAPIST_NAME
  PRACTICE_NAME
  SPECIALTY
  CITY
}

enum Role {
  therapist
  manager
  admin
}

enum BookingMode {
  DIRECTORY_ONLY
  FIRST_APPOINTMENT_REQUEST
}

enum BookingRequestStatus {
  PENDING
  CONFIRMED
  DECLINED
  EXPIRED
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  passwordHash           String?
  sessionToken           String?                 @unique
  role                   Role
  emailVerificationToken      String?
  emailVerifiedAt             DateTime?
  requiresEmailVerification   Boolean   @default(false)
  passwordResetToken          String?
  passwordResetExpiresAt      DateTime?
  emailOtpCode                String?
  emailOtpExpiresAt           DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  therapistProfile       Therapist?              @relation("TherapistUser")
  managerProfile         PracticeManager?
}

model Therapist {
  id                    String       @id @default(cuid())
  email                 String       @unique
  userId                String?      @unique
  user                  User?        @relation("TherapistUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName              String
  professionalTitle     String
  city                  String
  postalCode            String?
  street                String?
  houseNumber           String?
  locationPrecision     String       @default("approximate")
  bio                   String?
  homeVisit             Boolean      @default(false)
  isFreelancer          Boolean      @default(true)
  specializations       String
  languages             String
  certifications        String       @default("")
  kassenart             String       @default("")
  gender                String?
  availability          String       @default("")
  serviceRadiusKm       Float?
  latitude              Float?
  longitude             Float?
  homeLat               Float        @default(0)
  homeLng               Float        @default(0)
  isVisible             Boolean      @default(true)
  reviewStatus          ReviewStatus @default(PENDING_REVIEW)
  passwordHash          String?
  sessionToken          String?      @unique
  photo                 String?
  expoPushToken         String?
  taxRegistrationStatus String?
  healthAuthorityStatus String?
  complianceUpdatedAt   DateTime?
  invitedByPracticeId   String?
  onboardingStatus      String       @default("none")
  visibilityPreference  String       @default("hidden")
  isPublished           Boolean      @default(false)
  bookingMode           BookingMode  @default(DIRECTORY_ONLY)
  nextFreeSlotAt        DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  links                 TherapistPracticeLink[]
  invitations           Invitation[]
  managerAccount        PracticeManager? @relation("ManagerTherapist")
  documents             TherapistDocument[]
  bookingRequests       BookingRequest[]
}

model Practice {
  id                String       @id @default(cuid())
  name              String
  city              String
  address           String?
  phone             String?
  hours             String?
  lat               Float        @default(0)
  lng               Float        @default(0)
  reviewStatus      ReviewStatus @default(PENDING_REVIEW)
  description       String?
  homeVisit         Boolean      @default(false)
  inviteToken       String?      @unique
  logo              String?
  photos            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  links             TherapistPracticeLink[]
  invitations       Invitation[]
  assignments       ManagerPracticeAssignment[]
}

model PracticeManager {
  id           String    @id @default(cuid())
  email        String    @unique
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  passwordHash String
  sessionToken String?   @unique
  practiceId   String?
  therapistId  String?   @unique
  therapist    Therapist? @relation("ManagerTherapist", fields: [therapistId], references: [id])
  assignments  ManagerPracticeAssignment[]
  createdAt    DateTime  @default(now())
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  therapistId String
  practiceId  String
  email       String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model SearchSuggestion {
  id         String         @id @default(cuid())
  text       String
  normalized String
  type       SuggestionType
  entityId   String?
  weight     Int            @default(1)

  @@index([normalized])
}

model TherapistPracticeLink {
  id           String     @id @default(cuid())
  therapistId  String
  practiceId   String
  status       LinkStatus @default(PROPOSED)
  initiatedBy  String     @default("THERAPIST") // "ADMIN" | "THERAPIST"
  createdAt    DateTime   @default(now())
  therapist    Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice     Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([therapistId, practiceId])
}

model TherapistDocument {
  id           String    @id @default(cuid())
  therapistId  String
  filename     String    // stored filename (UUID-based, no path)
  originalName String    // original filename from upload
  mimetype     String
  uploadedAt   DateTime  @default(now())
  therapist    Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String
  authorName  String   @default("Revio Team")
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BookingRequest {
  id                   String               @id @default(cuid())
  therapistId          String
  therapist            Therapist            @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  status               BookingRequestStatus @default(PENDING)
  patientName          String
  patientEmail         String?
  patientPhone         String?
  preferredDays        String               @default("")
  preferredTimeWindows String               @default("")
  message              String?
  consentAcceptedAt    DateTime
  createdAt            DateTime             @default(now())
  responseDueAt        DateTime
  respondedAt          DateTime?
  confirmedSlotAt      DateTime?

  @@index([therapistId, status, createdAt])
}

model TherapistRemovalLog {
  id          String   @id @default(cuid())
  therapistId String
  practiceId  String
  managerId   String
  createdAt   DateTime @default(now())
}

model PracticeDeletionLog {
  id             String   @id @default(cuid())
  practiceId     String
  practiceName   String
  managerId      String
  reason         String
  reasonDetail   String?
  linkedTherapists Int    @default(0)
  createdAt      DateTime @default(now())
}

model CertificationOption {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String   @unique
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder, label])
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ManagerPracticeAssignment {
  id         String          @id @default(cuid())
  managerId  String
  practiceId String
  manager    PracticeManager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  practice   Practice        @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  createdAt  DateTime        @default(now())

  @@unique([managerId, practiceId])
}

// ─── Auth V2 ──────────────────────────────────────────────────────────────────

enum UserV2Role {
  patient
  therapist
  practice_manager
  admin

  @@map("user_v2_role")
}

model UserV2 {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  role         UserV2Role
  isVerified   Boolean    @default(false) @map("is_verified")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  patientProfile          PatientProfile?
  therapistProfileV2      TherapistProfileV2?
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]

  @@map("user_v2")
}

model PatientProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  user      UserV2   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("patient_profile")
}

model TherapistProfileV2 {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  user          UserV2   @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  licenseNumber String?  @map("license_number")
  isApproved    Boolean  @default(false) @map("is_approved")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("therapist_profile_v2")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      UserV2    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_token")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      UserV2    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      UserV2    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_token")
}
