generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  SUSPENDED
}

enum LinkStatus {
  PROPOSED
  CONFIRMED
  DISPUTED
  REJECTED
}

enum SuggestionType {
  THERAPIST_NAME
  PRACTICE_NAME
  SPECIALTY
  CITY
}

enum Role {
  therapist
  manager
  admin
}

model User {
  id               String                  @id @default(cuid())
  email            String                  @unique
  passwordHash     String?
  sessionToken     String?                 @unique
  role             Role
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  therapistProfile Therapist?              @relation("TherapistUser")
  managerProfile   PracticeManager?
}

model Therapist {
  id                    String       @id @default(cuid())
  email                 String       @unique
  userId                String?      @unique
  user                  User?        @relation("TherapistUser", fields: [userId], references: [id], onDelete: SetNull)
  fullName              String
  professionalTitle     String
  city                  String
  bio                   String?
  homeVisit             Boolean      @default(false)
  specializations       String
  languages             String
  certifications        String       @default("")
  kassenart             String       @default("")
  availability          String       @default("")
  isVisible             Boolean      @default(true)
  reviewStatus          ReviewStatus @default(PENDING_REVIEW)
  passwordHash          String?
  sessionToken          String?      @unique
  photo                 String?
  invitedByPracticeId   String?
  onboardingStatus      String       @default("none")
  visibilityPreference  String       @default("hidden")
  isPublished           Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  links                 TherapistPracticeLink[]
  invitations           Invitation[]
  managerAccount        PracticeManager? @relation("ManagerTherapist")
}

model Practice {
  id                String       @id @default(cuid())
  name              String
  city              String
  address           String?
  phone             String?
  hours             String?
  lat               Float        @default(0)
  lng               Float        @default(0)
  reviewStatus      ReviewStatus @default(PENDING_REVIEW)
  description       String?
  inviteToken       String?      @unique
  logo              String?
  photos            String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  links             TherapistPracticeLink[]
  invitations       Invitation[]
  manager           PracticeManager?
}

model PracticeManager {
  id           String    @id @default(cuid())
  email        String    @unique
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  passwordHash String
  sessionToken String?   @unique
  practiceId   String    @unique
  practice     Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  therapistId  String?   @unique
  therapist    Therapist? @relation("ManagerTherapist", fields: [therapistId], references: [id])
  createdAt    DateTime  @default(now())
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique
  therapistId String
  practiceId  String
  email       String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice    Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
}

model SearchSuggestion {
  id         String         @id @default(cuid())
  text       String
  normalized String
  type       SuggestionType
  entityId   String?
  weight     Int            @default(1)

  @@index([normalized])
}

model TherapistPracticeLink {
  id           String     @id @default(cuid())
  therapistId  String
  practiceId   String
  status       LinkStatus @default(PROPOSED)
  initiatedBy  String     @default("THERAPIST") // "ADMIN" | "THERAPIST"
  createdAt    DateTime   @default(now())
  therapist    Therapist  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  practice     Practice   @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@unique([therapistId, practiceId])
}
