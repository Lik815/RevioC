# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# Local SQLite (development)
DATABASE_URL="file:./prisma/prisma/dev.db"
# Production PostgreSQL (replace SQLite before going live)
# DATABASE_URL="postgresql://user:password@host:5432/revio?schema=public"

# ── Admin ─────────────────────────────────────────────────────────────────────
REVIO_ADMIN_TOKEN=change-me
REVIO_ADMIN_EMAIL=admin@revio.de
REVIO_ADMIN_PASSWORD=change-me

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get your key at https://resend.com
# Leave empty to disable email sending (invite/approval flows will log instead)
RESEND_API_KEY=

# ── Mobile deep-link base URL ─────────────────────────────────────────────────
# Used in invite e-mails. Set to your Expo/EAS URL in production.
MOBILE_URL=http://localhost:8081
