{
  "name": "revio",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @revio/api dev",
    "dev:admin": "pnpm --filter @revio/admin dev",
    "dev:site": "pnpm --filter @revio/site dev",
    "dev:mobile": "pnpm --filter @revio/mobile start",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @revio/api prisma:generate",
    "db:migrate": "pnpm --filter @revio/api prisma:migrate",
    "db:seed": "pnpm --filter @revio/api seed",
    "db:seed:koeln": "pnpm --filter @revio/api seed:koeln",
    "db:seed:practice-logos": "pnpm --filter @revio/api seed:practice-logos"
  },
  "dependencies": {
    "expo": "^55.0.8"
  },
  "devDependencies": {
    "next": "15.5.14",
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  }
}
